---
// Single-weight line icons for scenarios, replacing emoji so the iconography
// inherits the brand color and renders consistently across platforms.
interface Props {
  slug: string;
  size?: number;
}
const { slug, size = 28 } = Astro.props;

const paths: Record<string, string> = {
  'grad-school': 'M3 8L12 4L21 8L12 12L3 8ZM7 10V15C7 16 9.5 17.5 12 17.5C14.5 17.5 17 16 17 15V10M21 8V13',
  'job-hunt': 'M3 8H21V19H3V8ZM8 8V6C8 5 8.5 4.5 9.5 4.5H14.5C15.5 4.5 16 5 16 6V8M3 13H21',
  'data-analysis': 'M4 20V4M4 20H20M8 20V12M12 20V8M16 20V14M20 20V6',
  creative: 'M12 3C7 3 3 6.6 3 11C3 14 5 15.5 7 15.5C8 15.5 8.5 16 8.5 17C8.5 18.5 9.5 20 12 20C16.5 20 21 16.5 21 11C21 6.6 17 3 12 3ZM7.5 10.5H7.51M10 7H10.01M14 7H14.01M16.5 10.5H16.51',
  adventure: 'M3 19H21L15 7L11.5 13L9 9L3 19Z',
  'save-money': 'M12 3V21M16 6.5C16 5 14.5 4 12 4C9.5 4 8 5.2 8 7C8 11 16 9 16 13C16 15 14 16 12 16C9.5 16 7.5 15 7.5 13',
};
const d = paths[slug] ?? 'M5 12H19M12 5V19';
---

<svg
  class="scenario-icon-svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d={d} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
</svg>

<style>
  .scenario-icon-svg {
    color: var(--color-accent);
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import ScenarioIcon from '../../components/ScenarioIcon.astro';
import { loadResources } from '../../lib/catalog';
import { SCENARIOS } from '../../site.config';

// Resolve the catalog (Supabase with static JSON fallback), id = stable slug.
const resources = await loadResources();

// Resources curated for this scenario (membership defined in site.config).
const scenarioResources = resources.filter(SCENARIOS['data-analysis'].match);
---

<BaseLayout title="Data Analysis Resources | Free Stuff @ Dartmouth">
  <div class="scenario-page">
    <div class="scenario-hero">
      <div class="scenario-icon-large"><ScenarioIcon slug="data-analysis" size={48} /></div>
      <h1 class="scenario-title">Running data analysis?</h1>
      <p class="scenario-description">
        Whether you're crunching numbers for an econ thesis, analyzing survey data for psych research, or building models for a finance class — you have access to the same professional tools that analysts at Goldman Sachs and McKinsey use. No student licenses. The real thing.
      </p>
    </div>

    <div class="scenario-content">
      <div class="scenario-section">
        <h2 class="section-title">What you'll find here</h2>
        <ul class="benefit-list">
          <li><strong>Bloomberg Terminal</strong> — $25,000/year terminal. Walk into Feldberg Library and use it. Real-time market data, company financials, everything.</li>
          <li><strong>Statistical software</strong> — MATLAB, SPSS, SAS, JMP Pro. Pick your poison. All the heavy-duty stats tools.</li>
          <li><strong>WRDS</strong> — Wharton Research Data Services. Financial and economic data used by every top business school.</li>
          <li><strong>Qualtrics</strong> — Professional survey platform. Design studies, collect data, analyze results.</li>
          <li><strong>Statista</strong> — Market research and statistics database. Perfect for finding industry data fast.</li>
          <li><strong>JupyterHub & RStudio</strong> — Cloud-based Python and R environments. No local setup needed.</li>
        </ul>
      </div>

      <div class="resources-section">
        <h2 class="section-title">Your resources ({scenarioResources.length})</h2>
        <div class="resource-grid">
          {scenarioResources.map((resource) => (
            <div class="resource-item">
              <ResourceCard resource={resource} />
            </div>
          ))}
        </div>
      </div>

      <div class="cta-section">
        <p class="cta-text">Need something else?</p>
        <a href="/" class="cta-button">Browse all {resources.length} resources</a>
        <a href="/scenarios" class="cta-link-secondary">See other scenarios →</a>
      </div>
    </div>
  </div>

  <style>
    .scenario-page {
      max-width: 90rem;
      margin: 0 auto;
      padding: var(--space-2xl) var(--space-lg);
    }

    .scenario-hero {
      max-width: var(--measure);
      margin: 0 auto var(--space-3xl);
      text-align: center;
    }

    .scenario-icon-large {
      font-size: var(--text-6xl);
      line-height: 1;
      margin-bottom: var(--space-md);
    }

    .scenario-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-4xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
    }

    .scenario-description {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      margin: 0;
    }

    .scenario-content {
      display: flex;
      flex-direction: column;
      gap: var(--space-3xl);
    }

    .scenario-section {
      max-width: var(--measure);
      margin: 0 auto;
    }

    .section-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-2xl);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
    }

    .benefit-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .benefit-list li {
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      padding-left: var(--space-lg);
      position: relative;
    }

    .benefit-list li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: var(--color-accent);
      font-weight: 600;
    }

    .resources-section {
      width: 100%;
    }

    .resource-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .cta-section {
      max-width: var(--measure);
      margin: 0 auto;
      text-align: center;
      padding: var(--space-2xl) 0;
      border-top: var(--rule-thin) solid var(--color-border);
    }

    .cta-text {
      margin: 0 0 var(--space-md) 0;
      font-size: var(--text-lg);
      color: var(--color-ink-muted);
    }

    .cta-button {
      display: inline-block;
      padding: var(--space-sm) var(--space-lg);
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--color-paper);
      background: var(--color-accent);
      border: none;
      border-radius: var(--radius-sm);
      text-decoration: none;
      cursor: pointer;
      transition: background var(--dur-fast) var(--ease-out);
    }

    .cta-button:hover {
      background: var(--color-accent-hover);
    }

    .cta-link-secondary {
      display: block;
      margin-top: var(--space-sm);
      font-size: var(--text-base);
      font-weight: 500;
      color: var(--color-accent);
      text-decoration: none;
      transition: color var(--dur-fast) var(--ease-out);
    }

    .cta-link-secondary:hover {
      color: var(--color-accent-hover);
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .scenario-page {
        padding: var(--space-xl) var(--space-md);
      }

      .scenario-title {
        font-size: var(--text-3xl);
      }

      .scenario-description {
        font-size: var(--text-base);
      }

      .section-title {
        font-size: var(--text-xl);
      }

      .resource-grid {
        grid-template-columns: 1fr;
        gap: var(--space-md);
      }
    }
  </style>


  <script>
    import { initResourceInteractions } from '../../lib/resource-interactions';

    // Upvote + report behavior (shared across all pages).
    initResourceInteractions();
  </script>
</BaseLayout>

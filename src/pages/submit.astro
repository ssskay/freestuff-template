---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES, ELIGIBILITY, categoryLabel } from '../site.config';

const categories = CATEGORIES;
const eligibilityOptions = ELIGIBILITY;
---

<BaseLayout title="Submit a Resource | Free Stuff @ Dartmouth">
  <div class="submit-page">
    <div class="submit-header">
      <h1 class="page-title">Submit a free resource</h1>
      <p class="page-description">
        Found a free perk that's not listed? Share it with the community. All submissions go through a quick review before going live.
      </p>
      <p class="required-note">Fields marked <span class="required">*</span> are required.</p>
    </div>

    <form id="submit-form" class="submit-form">
      <div class="form-group">
        <label for="name" class="form-label">
          Resource name <span class="required">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-input"
          required
          placeholder="e.g., Microsoft 365 (Office)"
        />
      </div>

      <div class="form-group">
        <label for="url" class="form-label">
          URL <span class="required">*</span>
        </label>
        <input
          type="url"
          id="url"
          name="url"
          class="form-input"
          required
          placeholder="https://..."
        />
      </div>

      <div class="form-group">
        <label for="category" class="form-label">
          Category <span class="required">*</span>
        </label>
        <select id="category" name="category" class="form-select" required>
          <option value="">Select a category</option>
          {categories.map((cat) => (
            <option value={cat}>{categoryLabel(cat)}</option>
          ))}
        </select>
      </div>

      <fieldset class="form-group eligibility-fieldset">
        <legend class="form-label">
          Who's eligible? <span class="required" aria-hidden="true">*</span>
        </legend>
        <div class="checkbox-group">
          {eligibilityOptions.map((elig) => (
            <label class="checkbox-label">
              <input
                type="checkbox"
                name="eligibility"
                value={elig}
                class="checkbox-input"
              />
              <span class="checkbox-text">{elig}</span>
            </label>
          ))}
        </div>
        <span id="eligibility-error" class="field-error" role="alert"></span>
      </fieldset>

      <div class="form-group">
        <label for="description" class="form-label">
          Description <span class="required">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          class="form-textarea"
          rows="4"
          required
          placeholder="What is this resource and why is it useful? Be specific about what's included."
        ></textarea>
        <span class="form-hint">Try to match the tone of existing entries: helpful and direct.</span>
      </div>

      <div class="form-group">
        <label for="notes" class="form-label">
          Additional notes <span class="optional">(optional)</span>
        </label>
        <textarea
          id="notes"
          name="notes"
          class="form-textarea"
          rows="2"
          placeholder="Any caveats, restrictions, or insider tips?"
        ></textarea>
      </div>

      <div class="form-group">
        <label for="submitted_by" class="form-label">
          Your email <span class="optional">(optional)</span>
        </label>
        <input
          type="email"
          id="submitted_by"
          name="submitted_by"
          class="form-input"
          placeholder="you@dartmouth.edu"
        />
        <span class="form-hint">Optional, but we'll credit you if you want!</span>
      </div>

      <div class="form-actions">
        <button type="submit" class="submit-btn" id="submit-btn">
          Submit for review
        </button>
        <a href="/" class="cancel-link">Cancel</a>
      </div>

      <div id="form-message" class="form-message hidden" role="status" aria-live="polite"></div>
    </form>
  </div>

  <style>
    .submit-page {
      max-width: 48rem;
      margin: 0 auto;
      padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
    }

    .submit-header {
      margin-bottom: var(--space-2xl);
    }

    .page-title {
      font-family: var(--font-display);
      font-style: italic;
      font-size: var(--text-display);
      font-weight: 600;
      line-height: var(--leading-tight);
      color: var(--color-ink);
      margin: 0 0 var(--space-md) 0;
    }

    .page-description {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-ink-muted);
      margin: 0;
    }

    .submit-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .form-label {
      font-size: var(--text-base);
      font-weight: 500;
      color: var(--color-ink);
    }

    .required {
      color: var(--color-accent);
    }

    .optional {
      font-weight: 400;
      color: var(--color-ink-subtle);
    }

    .form-input,
    .form-select,
    .form-textarea {
      padding: var(--space-sm) var(--space-md);
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: var(--leading-normal);
      color: var(--color-ink);
      background: var(--color-paper);
      border: var(--rule-thin) solid var(--color-border-input);
      border-radius: var(--radius-md);
      transition: border-color var(--dur-fast) var(--ease-out),
                  box-shadow var(--dur-fast) var(--ease-out);
    }

    /* Reset the native fieldset chrome so the eligibility group matches others. */
    .eligibility-fieldset {
      border: 0;
      padding: 0;
      margin: 0;
      min-width: 0;
    }

    .eligibility-fieldset .form-label {
      padding: 0;
    }

    .required-note {
      margin: var(--space-xs) 0 0 0;
      font-size: var(--text-sm);
      color: var(--color-ink-muted);
    }

    .field-error {
      display: block;
      margin-top: var(--space-2xs);
      font-size: var(--text-sm);
      color: oklch(45% 0.15 25);
    }

    .field-error:empty {
      display: none;
    }

    .form-input::placeholder,
    .form-textarea::placeholder {
      color: var(--color-ink-subtle);
    }

    .form-input:hover,
    .form-select:hover,
    .form-textarea:hover {
      border-color: var(--color-border-strong);
    }

    .form-input:focus,
    .form-select:focus,
    .form-textarea:focus {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px var(--color-accent-subtle);
    }

    .form-textarea {
      resize: vertical;
      min-height: 4rem;
    }

    .form-hint {
      font-size: var(--text-sm);
      color: var(--color-ink-subtle);
      font-style: italic;
    }

    .checkbox-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .checkbox-label {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      cursor: pointer;
    }

    .checkbox-input {
      width: 1.125rem;
      height: 1.125rem;
      cursor: pointer;
      accent-color: var(--color-accent);
    }

    .checkbox-text {
      font-size: var(--text-base);
      color: var(--color-ink);
      text-transform: capitalize;
    }

    .form-actions {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      padding-top: var(--space-md);
    }

    .submit-btn {
      padding: var(--space-sm) var(--space-lg);
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: 500;
      color: var(--color-paper);
      background: var(--color-accent);
      border: none;
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: background var(--dur-fast) var(--ease-out);
    }

    .submit-btn:hover {
      background: var(--color-accent-hover);
    }

    .submit-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .cancel-link {
      font-size: var(--text-base);
      color: var(--color-ink-muted);
      text-decoration: none;
      transition: color var(--dur-fast) var(--ease-out);
    }

    .cancel-link:hover {
      color: var(--color-ink);
      text-decoration: underline;
    }

    .form-message {
      padding: var(--space-md);
      font-size: var(--text-base);
      line-height: var(--leading-normal);
      border-radius: var(--radius-md);
      margin-top: var(--space-md);
    }

    .form-message.hidden {
      display: none;
    }

    .form-message.success {
      color: var(--color-accent);
      background: var(--color-accent-subtle);
      border: var(--rule-thin) solid var(--color-accent);
    }

    .form-message.error {
      color: oklch(45% 0.15 25);
      background: oklch(95% 0.03 25);
      border: var(--rule-thin) solid oklch(80% 0.08 25);
    }

    @media (max-width: 768px) {
      .submit-page {
        padding: var(--space-2xl) var(--space-md) var(--space-xl);
      }

      .page-title {
        font-size: var(--text-3xl);
      }

      .page-description {
        font-size: var(--text-base);
      }

      .form-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .submit-btn {
        width: 100%;
      }
    }
  </style>

  <script>
    import { submitResource } from '../lib/supabase';

    const form = document.getElementById('submit-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const formMessage = document.getElementById('form-message') as HTMLDivElement;
    const eligibilityError = document.getElementById('eligibility-error') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Get form data
      const formData = new FormData(form);
      const eligibilityCheckboxes = form.querySelectorAll('input[name="eligibility"]:checked') as NodeListOf<HTMLInputElement>;
      const eligibility = Array.from(eligibilityCheckboxes).map(cb => cb.value);

      // Validate eligibility (custom control, so validate and announce here).
      if (eligibility.length === 0) {
        eligibilityError.textContent = 'Please select at least one option.';
        (form.querySelector('input[name="eligibility"]') as HTMLInputElement | null)?.focus();
        return;
      }
      eligibilityError.textContent = '';

      // Prepare submission data
      const submission = {
        name: formData.get('name') as string,
        url: formData.get('url') as string,
        category: formData.get('category') as string,
        description: formData.get('description') as string,
        eligibility,
        notes: formData.get('notes') as string || undefined,
        submitted_by: formData.get('submitted_by') as string || undefined,
      };

      // Disable submit button
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      try {
        const result = await submitResource(submission);

        if (result.success) {
          showMessage(
            'Thanks for your submission! We will review it shortly and add it to the catalog.',
            'success'
          );
          form.reset();

          // Redirect to home after 3 seconds
          setTimeout(() => {
            window.location.href = '/';
          }, 3000);
        } else {
          showMessage(
            result.message || 'Failed to submit resource. Please try again.',
            'error'
          );
        }
      } catch (error) {
        console.error('Submission error:', error);
        showMessage(
          'Something went wrong. Please try again later.',
          'error'
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit for review';
      }
    });

    function showMessage(message: string, type: 'success' | 'error') {
      formMessage.textContent = message;
      formMessage.className = `form-message ${type}`;
    }
  </script>
</BaseLayout>
